---
import { withBase } from '@/lib/base';
const pagefindUrl = withBase('/pagefind/pagefind.js');
---

<dialog
  id="search-dialog"
  class="search-dialog"
  aria-labelledby="search-title"
  data-pagefind-url={pagefindUrl}
>
  <div class="search-panel">
    <header>
      <div>
        <span class="eyebrow">SEARCH THE ARCHIVE</span><h2 id="search-title">寻找一篇文字</h2>
      </div><button type="button" class="icon-button search-close" aria-label="关闭搜索">×</button>
    </header><label class="search-field"
      ><span>⌕</span><input
        id="search-input"
        type="search"
        placeholder="标题、正文、标签……"
        autocomplete="off"
      /><kbd>ESC</kbd></label
    ><p id="search-status" class="search-status">输入关键词开始搜索；支持中文。</p><ol
      id="search-results"
      class="search-results"
    >
    </ol>
  </div>
</dialog>
<script>
  interface SearchItem {
    url: string;
    excerpt: string;
    meta: { title?: string };
  }
  interface Pagefind {
    init(): Promise<void>;
    search(query: string): Promise<{
      results: Array<{ data(): Promise<SearchItem> }>;
    }>;
  }
  declare global {
    interface Window {
      __YUMENO_SEARCH_BOUND__?: boolean;
      __YUMENO_PAGEFIND__?: Pagefind;
      __YUMENO_PAGEFIND_LOADING__?: Promise<Pagefind>;
    }
  }
  const currentDialog = () => document.querySelector<HTMLDialogElement>('#search-dialog');
  async function loadPagefind(dialog: HTMLDialogElement) {
    if (window.__YUMENO_PAGEFIND__) return window.__YUMENO_PAGEFIND__;
    if (!window.__YUMENO_PAGEFIND_LOADING__) {
      const pagefindUrl = dialog.dataset.pagefindUrl;
      if (!pagefindUrl) throw new Error('Missing Pagefind URL');
      window.__YUMENO_PAGEFIND_LOADING__ = import(/* @vite-ignore */ pagefindUrl).then(
        async (module: Pagefind) => {
          await module.init();
          window.__YUMENO_PAGEFIND__ = module;
          return module;
        },
      );
    }
    try {
      return await window.__YUMENO_PAGEFIND_LOADING__;
    } catch (error) {
      delete window.__YUMENO_PAGEFIND_LOADING__;
      throw error;
    }
  }
  async function openSearch() {
    bindCurrentDialog();
    const dialog = currentDialog();
    const input = dialog?.querySelector<HTMLInputElement>('#search-input');
    const status = dialog?.querySelector<HTMLElement>('#search-status');
    if (!dialog || !input || !status) return;
    if (!dialog.open) dialog.showModal();
    input.focus();
    try {
      await loadPagefind(dialog);
      if (input.value.trim()) await search(input);
    } catch {
      status.textContent = '搜索索引暂时无法加载，请稍后重试。';
    }
  }
  async function search(input: HTMLInputElement) {
    const dialog = input.closest<HTMLDialogElement>('#search-dialog');
    const results = dialog?.querySelector<HTMLOListElement>('#search-results');
    const status = dialog?.querySelector<HTMLElement>('#search-status');
    if (!dialog || !results || !status) return;
    const query = input.value.trim();
    if (!query) {
      results.innerHTML = '';
      status.textContent = '输入关键词开始搜索；支持中文。';
      return;
    }
    const pagefind = window.__YUMENO_PAGEFIND__;
    if (!pagefind) {
      status.textContent = '正在加载搜索索引……';
      return;
    }
    const response = await pagefind.search(query);
    const items = await Promise.all(response.results.slice(0, 8).map((item) => item.data()));
    results.innerHTML = items
      .map(
        (item) =>
          `<li><a href="${item.url}"><strong>${item.meta.title ?? item.url}</strong><p>${item.excerpt}</p></a></li>`,
      )
      .join('');
    status.textContent = `找到 ${response.results.length} 个结果`;
  }
  function bindCurrentDialog() {
    const dialog = currentDialog();
    const input = dialog?.querySelector<HTMLInputElement>('#search-input');
    if (input && !input.dataset.searchBound) {
      input.dataset.searchBound = 'true';
      input.addEventListener('input', () => search(input));
    }
    if (dialog && !dialog.dataset.searchBound) {
      dialog.dataset.searchBound = 'true';
      dialog.addEventListener('click', (event) => {
        if (event.target === dialog) dialog.close();
      });
    }
  }
  if (!window.__YUMENO_SEARCH_BOUND__) {
    window.__YUMENO_SEARCH_BOUND__ = true;
    document.addEventListener('click', (event) => {
      const target = event.target as HTMLElement;
      if (target.closest('.search-trigger')) openSearch();
      if (target.closest('.search-close')) currentDialog()?.close();
    });
    document.addEventListener('keydown', (event) => {
      if (
        (event.metaKey || event.ctrlKey) &&
        event.key.toLowerCase() === 'k' &&
        !['INPUT', 'TEXTAREA'].includes(document.activeElement?.tagName ?? '')
      ) {
        event.preventDefault();
        openSearch();
      }
      if (event.key === 'Escape') currentDialog()?.close();
    });
    document.addEventListener('astro:page-load', bindCurrentDialog);
  }
  bindCurrentDialog();
</script>
