---
import {
  dataOf,
  formatDate,
  publishedOf,
  routeFor,
  sectionInfo,
  type UnifiedEntry,
} from '@/lib/content';
import { withBase } from '@/lib/base';
import { responsiveImage } from '@/lib/images';
interface Props {
  item: UnifiedEntry;
  featured?: boolean;
}
const { item, featured = false } = Astro.props;
const data = dataOf(item);
const coverImage = data.cover ? responsiveImage(data.cover) : undefined;
---

<article
  class:list={['content-card', { featured, 'has-cover': Boolean(coverImage) }]}
  data-section={data.section}
>
  {
    coverImage && (
      <a class="card-cover" href={withBase(routeFor(item))} aria-hidden="true" tabindex="-1">
        <img
          src={coverImage.src}
          srcset={coverImage.srcset}
          sizes="(max-width: 700px) calc(100vw - 28px), (max-width: 1228px) 39vw, 460px"
          width={coverImage.width}
          height={coverImage.height}
          alt=""
          loading="lazy"
          fetchpriority="low"
          decoding="async"
        />
      </a>
    )
  }
  <div class="card-copy">
    <div class="card-meta">
      <span>{sectionInfo[data.section].label}</span>{data.pinned && <span>置顶</span>}<time
        datetime={publishedOf(item).toISOString()}>{formatDate(publishedOf(item))}</time
      >{item.kind === 'html' && <span>HTML</span>}
    </div>
    <h2><a href={withBase(routeFor(item))}>{data.title}</a></h2><p>{data.description}</p>
    <div class="card-foot">
      <ul aria-label="标签">
        {
          data.tags.slice(0, 3).map((tag) => (
            <li>
              <a href={withBase(`/tags/${encodeURIComponent(tag)}/`)}>#{tag}</a>
            </li>
          ))
        }
      </ul><a
        class="read-link"
        href={withBase(routeFor(item))}
        aria-label={`阅读《${data.title}》全文`}>阅读全文 <span aria-hidden="true">→</span></a
      >
    </div>
  </div>
</article>
