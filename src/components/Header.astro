---
import { siteConfig, sceneConfig } from '@/lib/config';
import { withBase } from '@/lib/base';
import { responsiveImage } from '@/lib/images';
const currentPath = Astro.url.pathname;
const active = (href: string) =>
  href === '/' ? currentPath === withBase('/') : currentPath.startsWith(withBase(href));
const brand = siteConfig.brand;
const brandImage = brand.image ? responsiveImage(brand.image) : undefined;
---

<header class="site-header">
  <a
    class:list={['brand', { 'brand-image': brand.mode === 'image' }]}
    href={withBase('/')}
    aria-label={`${brand.text} 首页`}
  >
    {
      brand.mode === 'image' && brandImage ? (
        <img
          src={brandImage.src}
          srcset={brandImage.srcset}
          sizes={`${brand.width ?? 168}px`}
          width={brandImage.width}
          height={brandImage.height}
          alt={brand.text}
          style={`--brand-width:${brand.width ?? 168}px`}
        />
      ) : (
        <>
          <>
            <span class="brand-star" aria-hidden="true">
              ✦
            </span>
            <span>{brand.text}</span>
          </>
        </>
      )
    }
  </a>
  <nav class="desktop-nav" aria-label="主要导航">
    {
      siteConfig.navigation.map((item) => (
        <a href={withBase(item.href)} aria-current={active(item.href) ? 'page' : undefined}>
          {item.label}
        </a>
      ))
    }
  </nav>
  <div class="header-actions">
    {
      siteConfig.features.search && (
        <button
          class="icon-button search-trigger"
          type="button"
          aria-label="打开搜索"
          title="搜索（Ctrl/⌘ K）"
        >
          <svg viewBox="0 0 24 24" aria-hidden="true">
            <circle cx="10.5" cy="10.5" r="5.75" />
            <path d="m15 15 4.25 4.25" />
          </svg>
        </button>
      )
    }
    <button class="icon-button theme-trigger" type="button" aria-label="切换主题" title="切换主题"
      ><svg viewBox="0 0 24 24" aria-hidden="true">
        <circle cx="12" cy="12" r="7.5"></circle>
        <path d="M12 4.5a7.5 7.5 0 0 0 0 15z" class="theme-half"></path>
      </svg></button
    >
    {
      siteConfig.features.sceneSwitcher && (
        <details class="scene-menu">
          <summary class="icon-button" aria-label="选择场景" title="场景">
            <svg viewBox="0 0 24 24" aria-hidden="true">
              <path d="m11.5 3 1.7 5.3 5.3 1.7-5.3 1.7-1.7 5.3-1.7-5.3L4.5 10l5.3-1.7L11.5 3z" />
              <path d="m18.5 15 .7 2.1 2.1.7-2.1.7-.7 2.1-.7-2.1-2.1-.7 2.1-.7.7-2.1z" />
            </svg>
          </summary>
          <div class="scene-popover">
            <p>
              视觉场景 <span data-current-scene />
            </p>
            <button type="button" data-scene-option="auto" aria-pressed="true">
              自动选择
            </button>
            {sceneConfig.scenes
              .filter((scene) => scene.manualSelectable !== false)
              .map((scene) => (
                <button type="button" data-scene-option={scene.id} aria-pressed="false">
                  {scene.label}
                </button>
              ))}
          </div>
        </details>
      )
    }
    <button
      class="icon-button menu-trigger"
      type="button"
      aria-label="打开菜单"
      aria-expanded="false"
      aria-controls="mobile-menu"
      ><svg viewBox="0 0 24 24" aria-hidden="true">
        <path d="M5 7h14M5 12h14M5 17h14"></path>
      </svg></button
    >
  </div>
  <nav id="mobile-menu" class="mobile-nav" aria-label="移动端导航" hidden>
    {
      siteConfig.navigation.map((item) => (
        <a href={withBase(item.href)} aria-current={active(item.href) ? 'page' : undefined}>
          {item.label}
        </a>
      ))
    }
    {
      siteConfig.features.search && (
        <button type="button" class="mobile-search search-trigger">
          搜索站内内容
        </button>
      )
    }
  </nav>
</header>

<script>
  declare global {
    interface Window {
      __YUMENO_HEADER_BOUND__?: boolean;
    }
  }
  function setTheme(theme: 'light' | 'dark') {
    document.documentElement.dataset.theme = theme;
    document.documentElement.dataset.themePreference = theme;
    const trigger = document.querySelector<HTMLButtonElement>('.theme-trigger');
    if (trigger) {
      const label = theme === 'dark' ? '切换到亮色模式' : '切换到暗色模式';
      trigger.setAttribute('aria-label', label);
      trigger.title = label;
    }
  }
  function applyTheme() {
    let preference = 'system';
    try {
      preference = localStorage.getItem('yumeno:theme') ?? 'system';
    } catch {}
    const dark =
      preference === 'dark' ||
      (preference === 'system' && matchMedia('(prefers-color-scheme: dark)').matches);
    setTheme(dark ? 'dark' : 'light');
  }
  if (!window.__YUMENO_HEADER_BOUND__) {
    window.__YUMENO_HEADER_BOUND__ = true;
    document.addEventListener('click', (event) => {
      const target = event.target as HTMLElement;
      if (target.closest('.theme-trigger')) {
        const current = document.documentElement.dataset.theme === 'dark' ? 'dark' : 'light';
        const next = current === 'dark' ? 'light' : 'dark';
        try {
          localStorage.setItem('yumeno:theme', next);
        } catch {}
        setTheme(next);
      }
      const button = target.closest<HTMLButtonElement>('.menu-trigger');
      if (button) {
        const menu = document.querySelector<HTMLElement>('#mobile-menu');
        if (!menu) return;
        menu.hidden = !menu.hidden;
        button.setAttribute('aria-expanded', String(!menu.hidden));
      }
      if (target.closest('.mobile-nav a')) {
        const menu = document.querySelector<HTMLElement>('#mobile-menu');
        if (menu) menu.hidden = true;
      }
    });
    matchMedia('(prefers-color-scheme: dark)').addEventListener('change', applyTheme);
    document.addEventListener('astro:page-load', applyTheme);
  }
  applyTheme();
</script>
