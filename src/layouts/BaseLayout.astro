---
import { ClientRouter } from 'astro:transitions';
import Header from '@/components/Header.astro';
import Footer from '@/components/Footer.astro';
import SceneBackdrop from '@/components/SceneBackdrop.astro';
import ScenePreload from '@/components/ScenePreload.astro';
import SearchDialog from '@/components/SearchDialog.astro';
import MusicPlayer from '@/components/MusicPlayer.astro';
import ClientEnhancements from '@/components/ClientEnhancements.astro';
import NavigationCache from '@/components/NavigationCache.astro';
import { siteConfig } from '@/lib/config';
import { absoluteUrl, withBase } from '@/lib/base';
import '@/styles/global.css';
interface Props {
  title?: string;
  description?: string;
  image?: string | undefined;
  page?: string;
  section?: string;
  type?: 'website' | 'article';
  published?: Date | undefined;
  updated?: Date | undefined;
}
const {
  title,
  description = siteConfig.description,
  image,
  page = 'page',
  section,
  type = 'website',
  published,
  updated,
} = Astro.props;
const fullTitle = title ? `${title} · ${siteConfig.shortName}` : siteConfig.name;
const routePath = Astro.url.pathname.replace(import.meta.env.BASE_URL, '/');
const canonical = absoluteUrl(routePath);
const shareImage = image ? absoluteUrl(image) : undefined;
---

<!doctype html>
<html lang={siteConfig.language}>
  <head
    ><meta charset="UTF-8" /><meta name="viewport" content="width=device-width" /><ScenePreload
      {page}
      {section}
    /><meta name="generator" content={Astro.generator} /><title>{fullTitle}</title><meta
      name="description"
      content={description}
    /><link rel="canonical" href={canonical} /><link
      rel="stylesheet"
      href={withBase('/fonts/serif.css')}
    /><link rel="icon" href={withBase('/favicon.svg')} /><link
      rel="alternate"
      type="application/rss+xml"
      title={siteConfig.name}
      href={withBase('/rss.xml')}
    /><meta property="og:title" content={fullTitle} /><meta
      property="og:description"
      content={description}
    /><meta property="og:type" content={type} /><meta property="og:url" content={canonical} />{
      shareImage && <meta property="og:image" content={shareImage} />
    }
    {published && <meta property="article:published_time" content={published.toISOString()} />}
    {updated && <meta property="article:modified_time" content={updated.toISOString()} />}<meta
      name="twitter:card"
      content={shareImage ? 'summary_large_image' : 'summary'}
    /><meta name="theme-color" media="(prefers-color-scheme: light)" content="#fbfaf8" /><meta
      name="theme-color"
      media="(prefers-color-scheme: dark)"
      content="#17171d"
    /><slot name="head" /><ClientRouter fallback="animate" /><NavigationCache /><script is:inline>
      try {
        const p = localStorage.getItem('yumeno:theme') ?? 'system';
        const d =
          p === 'dark' || (p === 'system' && matchMedia('(prefers-color-scheme:dark)').matches);
        document.documentElement.dataset.theme = d ? 'dark' : 'light';
        document.documentElement.dataset.themePreference = p;
      } catch {}
    </script></head
  ><body data-page={page} data-section={section}
    ><div class="reading-progress" aria-hidden="true"><span></span></div><a
      class="skip-link"
      href="#main-content">跳到正文</a
    ><SceneBackdrop /><div class="site-shell">
      <Header /><main id="main-content"><slot /></main><Footer />
    </div>{siteConfig.features.search && <SearchDialog />}<MusicPlayer /><ClientEnhancements
    /></body>
</html>
