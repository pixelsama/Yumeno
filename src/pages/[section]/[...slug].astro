---
import ArticleLayout from '@/layouts/ArticleLayout.astro';
import { render } from 'astro:content';
import { getMarkdownEntries, getOriginalChapters, sectionInfo } from '@/lib/content';
export async function getStaticPaths() {
  const entries = await getMarkdownEntries();
  return entries.map((entry) => ({
    params: { section: sectionInfo[entry.data.section].path, slug: entry.data.slug },
    props: { entry, all: entries },
  }));
}
const { entry, all } = Astro.props;
const { Content, headings } = await render(entry);
const same = all.filter((item) => item.data.section === entry.data.section);
const index = same.findIndex((item) => item.id === entry.id);
const related = all
  .filter(
    (item) => item.id !== entry.id && item.data.tags.some((tag) => entry.data.tags.includes(tag)),
  )
  .slice(0, 3);
const chapters = entry.data.series ? getOriginalChapters(all, entry.data.series) : [];
---

<ArticleLayout
  entry={entry}
  headings={headings}
  body={entry.body ?? ''}
  previous={same[index + 1]}
  next={same[index - 1]}
  related={related}
  seriesChapters={chapters}><Content /></ArticleLayout
>
